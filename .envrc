# ============================================================================
# direnv + Nix dev environment.
# Add packages to nix-config/flake.nix, not here.
# Any change to this file requires running `direnv allow` again.
# ============================================================================

# Bootstrap nix-direnv (provides the `use flake` integration with a devShell
# cache so re-entering the directory doesn't rebuild the environment).
NIX_DIRENV_VERSION="3.1.0"
NIX_DIRENV_SHA256="sha256-yMJ2OVMzrFaDPn7q8nCBZFRYpL/f0RcHzhmw/i6btJM="
if ! has nix_direnv_version || ! nix_direnv_version "$NIX_DIRENV_VERSION"; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/$NIX_DIRENV_VERSION/direnvrc" "$NIX_DIRENV_SHA256"
fi

# Load the Go toolchain (and anything else) declared in nix-config/flake.nix.
use flake path:./nix-config

# Allow per-developer local overrides without touching this file.
source_env_if_exists .envrc.local
