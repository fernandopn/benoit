# Required for tui/ssh/channel_listener commands when using the default
# -provider openai
OPENAI_API_KEY=

# Required for tui/ssh/channel_listener commands when using -provider openrouter
OPENROUTER_API_KEY=

# Required only for channel_listener --channel telegram
# Optional in tui/ssh to enable send_channel_message tool
TELEGRAM_API_KEY=

# Telegram recipient allowlist for channel_listener (comma-separated user IDs)
# Empty means deny all users
TELEGRAM_ALLOWED_USERS=

# Required for ssh command (comma-separated authorized public keys)
# Example format: "ssh-ed25519 AAAA... user@host,ecdsa-sha2-nistp256 AAAA... other@host"
SSH_ALLOWED_PUBLIC_KEYS=

# Optional; enables Maton tools (calendar/gmail)
MATON_API_KEY=
